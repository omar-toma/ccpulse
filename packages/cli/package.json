{
  "name": "@omartoma/ccpulse",
  "version": "0.1.9",
  "description": "Real-time analytics dashboard for Claude Code sessions",
  "type": "module",
  "bin": {
    "ccpulse": "./dist/bin.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/bin.ts --format esm --clean --target node22 --external chokidar",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "cd ../.. && pnpm build && cp README.md packages/cli/README.md"
  },
  "dependencies": {
    "chokidar": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "ccpulse-core": "workspace:*",
    "ccpulse-daemon": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "keywords": ["claude", "claude-code", "analytics", "monitoring", "dashboard", "tokens", "telemetry"],
  "license": "MIT",
  "author": "omartoma",
  "engines": {
    "node": ">=22.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omar-toma/ccpulse.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/omar-toma/ccpulse#readme",
  "bugs": {
    "url": "https://github.com/omar-toma/ccpulse/issues"
  }
}
